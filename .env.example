# ===========================================
# FiscalFlow Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://fiscalflow:fiscalflow@localhost:5432/fiscalflow

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fiscalflow-documents

# --- AI API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- JWT Auth ---
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- Google OAuth (Sign in with Google) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# --- GoCardless / Nordigen (Bank Integration PSD2) ---
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_BASE_URL=https://bankaccountdata.gocardless.com/api/v2

# --- Frontend URL ---
FRONTEND_URL=http://localhost:3000

# --- Google Drive Integration ---
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/integrations/callback/google-drive

# --- Dropbox Integration ---
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REDIRECT_URI=http://localhost:3000/integrations/callback/dropbox

# --- OneDrive / Microsoft Integration ---
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_REDIRECT_URI=http://localhost:3000/integrations/callback/onedrive
ONEDRIVE_TENANT_ID=common
