# Copy/paste these into the MinIO Coolify resource — Environment Variables tab.
# Generate MINIO_ROOT_PASSWORD with: openssl rand -base64 32

MINIO_ROOT_USER=fiscalflow
MINIO_ROOT_PASSWORD=change-me-use-openssl-rand-base64-32
MINIO_BUCKET=fiscalflow-documents

# Optional: set to your MinIO console subdomain so the browser redirects work.
# MINIO_BROWSER_REDIRECT_URL=https://storage-admin.fiscaalflow.nl
